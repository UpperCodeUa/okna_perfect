{
  "name": "app",
  "private": "true",
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.0-beta.1",
    "esbuild": "^0.19.8",
    "fslightbox": "^3.4.1",
    "sass": "^1.69.5",
    "swiper": "^11.0.5",
    "three": "^0.160.0"
  },
  "scripts": {
    "build": "esbuild app/javascript/*.* --bundle --sourcemap --outdir=app/assets/builds/js --minify",
    "build:css": "sass ./app/assets/stylesheets/application.sass.scss:./app/assets/builds/css/application.min.css ./app/assets/stylesheets/admin.sass.scss:./app/assets/builds/css/admin.min.css --no-source-map --load-path=node_modules --style compressed"
  }
}
