                .line
                  p.weight  =t('sliding.text8')
                  .logo-wrapper
                    .logo
                      = image_tag 'sliding-systems/pvc/wink.jpg', alt: 'logo', title: 'Perfect'
                .line
                  p.weight  =t('sliding.text9')
                  .colors-box
                    .color.white  =t('sliding.text10')
