    section.category
      .box
        h2.h2
          | VEKA
          span.red ecosol 70
        .products-wrapper
          .left
            = video_tag 'sliding-systems/pvc/video/ecosol.mp4', autoplay: "", muted:"", loop:"", playsinline:"", preload: "auto"
          .right
            .top-card
              h2.h2.transform VEKA <span class="red"> ECOSOL 70</span>
              .subtitle =t('page-hybrid.technical.title')
              .card-content
                .line
                  p.weight =t('sliding.text1')
