            .button-box
              .swiper-pagination
              .swiper-button-prev
              .swiper-button-next
          .main-item
            .subtitle =t('navbar.hybrid')
  section.service.category
    .container
      h2.h2
        =t('page-hybrid.title1')
        span.red
          =t('page-hybrid.title2')
      .box.small-padding
        - case I18n.locale
        - when :es
          .video-wrapper
            = video_tag 'hybrid/video2esp.mp4', autoplay: "", muted:"", loop:"", playsinline:"", preload: "auto", class: 'video'
            a.scale href=image_path("hybrid/video2esp.mp4") data-fslightbox="video2esp"
        - when :it
          .video-wrapper
            = video_tag 'hybrid/video2it.mp4', autoplay: "", muted:"", loop:"", playsinline:"", preload: "auto", class: 'video'
            a.scale href=image_path("hybrid/video2it.mp4") data-fslightbox="video2it"
        - when :ua
          .video-wrapper
            = video_tag 'hybrid/video2ua.mp4', autoplay: "", muted:"", loop:"", playsinline:"", preload: "auto", class: 'video'
            a.scale href=image_path("hybrid/video2ua.mp4") data-fslightbox="video2ua"
        -else
          .video-wrapper
            = video_tag 'hybrid/video2eng.mp4', autoplay: "", muted:"", loop:"", playsinline:"", preload: "auto", class: 'video'
            a.scale href=image_path("hybrid/video2eng.mp4") data-fslightbox="video2eng"
